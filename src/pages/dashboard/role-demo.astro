---
/**
 * Example dashboard page showing how to use RoleGuard and RouteGuard components
 * This demonstrates conditional rendering based on user roles
 */
import DashBoardLayout from "@/layouts/DashBoardLayout.astro";
import RouteGuard from "@/components/RouteGuard.astro";
import RoleGuard from "@/components/RoleGuard.astro";
import { Roles } from "@/config/routesConfig";

// This ensures only users with proper roles can access this page
---

<RouteGuard requiredRoles={[Roles.OWNER, Roles.ADMIN, Roles.WORKER]}>
  <DashBoardLayout title="Dashboard - Smart Suite">
    <div class="space-y-6">
      <h1 class="text-3xl font-bold text-gray-900">Dashboard</h1>
      
      <!-- This section is visible to everyone who can access the dashboard -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-xl font-semibold mb-4">Welcome to Smart Suite</h2>
        <p class="text-gray-600">
          This dashboard gives you access to all the tools you need to manage your hotel.
        </p>
      </div>
      
      <!-- This section is only visible to owners and admins -->
      <RoleGuard allowedRoles={[Roles.OWNER, Roles.ADMIN]}>
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-xl font-semibold mb-4">Analytics Overview</h2>
          <p class="text-gray-600">
            Summary of key metrics and performance indicators.
          </p>
          <div class="mt-4">
            <a href="/dashboard/analytics" class="text-primary-green hover:text-secondary-green1">
              View detailed analytics →
            </a>
          </div>
        </div>
      </RoleGuard>
      
      <!-- This section is visible to all staff members -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-xl font-semibold mb-4">Room Status</h2>
        <p class="text-gray-600">
          Current occupancy and room availability.
        </p>
        <div class="mt-4">
          <a href="/dashboard/rooms" class="text-primary-green hover:text-secondary-green1">
            Manage rooms →
          </a>
        </div>
      </div>
      
      <!-- Owner-only section -->
      <RoleGuard allowedRoles={[Roles.OWNER]}>
        <div class="bg-amber-50 rounded-lg shadow p-6 border border-amber-200">
          <h2 class="text-xl font-semibold mb-4">Owner Controls</h2>
          <p class="text-amber-800">
            This section contains owner-only controls for organization management.
          </p>
          <div class="mt-4">
            <a href="/dashboard/organization" class="text-primary-green hover:text-secondary-green1">
              Manage organization →
            </a>
          </div>
        </div>
      </RoleGuard>
      
      <!-- Admin-only section -->
      <RoleGuard allowedRoles={[Roles.ADMIN]}>
        <div class="bg-blue-50 rounded-lg shadow p-6 border border-blue-200">
          <h2 class="text-xl font-semibold mb-4">Administrator Tools</h2>
          <p class="text-blue-800">
            Special tools for hotel administrators.
          </p>
        </div>
      </RoleGuard>
      
      <!-- Example of showing alternative content -->
      <RoleGuard allowedRoles={[Roles.OWNER]} showAlternative={true}>
        <div class="bg-green-50 rounded-lg shadow p-6 border border-green-200">
          <h2 class="text-xl font-semibold mb-4">Revenue Reports</h2>
          <p class="text-green-800">
            Detailed financial reports and revenue forecasts.
          </p>
        </div>
        
        <div slot="alternative" class="bg-gray-50 rounded-lg shadow p-6">
          <h2 class="text-xl font-semibold mb-4">Hotel Performance</h2>
          <p class="text-gray-600">
            View the general performance metrics of the hotel.
            <span class="block mt-2 text-sm text-gray-500">
              (Detailed revenue reports are only available to owners)
            </span>
          </p>
        </div>
      </RoleGuard>
    </div>
  </DashBoardLayout>
</RouteGuard>
