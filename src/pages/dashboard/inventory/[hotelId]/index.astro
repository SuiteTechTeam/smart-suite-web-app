---
import DashBoardLayout from "@/layouts/DashBoardLayout.astro";


const hotelId = Astro.params.hotelId;
---

<DashBoardLayout title="Inventory - SmartSuite">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-3xl font-bold text-gray-900">Inventory</h1>
        <a href={`/dashboard/hotel/${hotelId}/inventory/new`} class="bg-primary
            text-black
            hover:bg-secondary-green1
            focus:ring-4
            focus:outline-none
            focus:ring-secondary-green1
            font-medium
            rounded-lg
            text-sm
            px-5
            py-2.5  
            text-center">
            Add New Item
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {Array.from({ length: 6 }).map((_, index) => (
            <div class="bg-white shadow-md rounded-lg p-4">
                <h2 class="text-xl font-semibold mb-2">Item {index + 1}</h2>
                <p class="text-gray-700">Description of the item goes here.</p>
                <div class="mt-4">
                    <a href={`/dashboard/hotel/${hotelId}/inventory/${index}`} class="text-primary-green hover:text-secondary-green1">
                        View Details
                    </a>
                </div>
            </div>
        ))}
    </div>
</DashBoardLayout>