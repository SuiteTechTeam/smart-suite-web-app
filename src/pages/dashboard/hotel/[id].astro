---
import MainLayout from "@/layouts/MainLayout.astro";

// Get the hotel ID from the URL
const { id } = Astro.params;
const isNewHotel = id === 'new';

// In a real application, you would check authentication
// This is a placeholder for demonstration
const isAuthenticated = true;
const userRole = "owner";

if (!isAuthenticated) {
  return Astro.redirect("/sign-in");
}

if (userRole !== "owner") {
  return Astro.redirect("/");
}

// Mock hotel data for demonstration (in a real app, fetch from API based on ID)
const hotel = isNewHotel ? {
  id: 'new',
  name: '',
  address: '',
  description: '',
  email: '',
  phone: '',
  amenities: [
    { name: "Wi-Fi", enabled: false, icon: "wifi" },
    { name: "Breakfast included", enabled: false, icon: "coffee" },
    { name: "Free parking", enabled: false, icon: "car" },
    { name: "Outdoor pool", enabled: false, icon: "water" },
    { name: "Gym", enabled: false, icon: "dumbbell" },
    { name: "Restaurant", enabled: false, icon: "utensils" }
  ],
  images: []
} : {
  id: 1,
  name: "Royal Decameron Punta Sal",
  address: "Av. Panamericana N, Punta Sal 24560",
  description: "This vibrant all-inclusive hotel is nestled among palm trees on Punta Sal Beach, 5 km from the town center and 89 km from Tumbes Airport. Simple rooms feature a terrace or balcony, flat-screen TV, and internet access (chargeable); some have a sitting area. Free amenities include water sports, evening entertainment, and beach equipment rentals, plus meals and drinks served at 3 restaurants and 5 bars. Other amenities include a lively nightclub, gardens, and a long beach with cabanas. There's also an outdoor pool, a whirlpool, and a gym.",
  email: "bookings@decameron.com",
  phone: "073 55 4877",
  amenities: [
    { name: "Paid Wi-Fi", enabled: true, icon: "wifi" },
    { name: "Breakfast included", enabled: true, icon: "coffee" },
    { name: "Free parking", enabled: true, icon: "car" },
    { name: "Outdoor pool", enabled: true, icon: "water" },
    { name: "Gym", enabled: true, icon: "dumbbell" },
    { name: "Restaurant", enabled: true, icon: "utensils" }
  ],
  images: [
    "/hotel1-aerial.jpg",
    "/hotel1-room.jpg",
    "/hotel1-beach.jpg"
  ]
};

const pageTitle = isNewHotel ? "Add New Hotel" : "Edit Hotel";
---

<MainLayout title={`${pageTitle} - Smart Suite`}>
  <div class="min-h-screen bg-gray-50">
    <!-- Navigation Header -->
    <header class="bg-white shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center h-16">
        <div class="flex items-center">
          <a href="/" class="flex items-center text-primary-green font-bold text-xl">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
            Smart Suite
          </a>
        </div>
        <div class="flex items-center">
          <button class="mr-4 relative">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
            </svg>
          </button>
          <span class="mr-4">ES</span>
          <button class="h-10 w-10 rounded-full bg-gray-500 flex items-center justify-center text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Back Button -->
      <div class="mb-6">
        <a href="/dashboard" class="text-primary-green hover:text-primary-green flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"></path>
          </svg>
          Back to Dashboard
        </a>
      </div>
      
      <!-- Form Title -->
      <div class="bg-white shadow rounded-lg overflow-hidden mb-8">
        <div class="p-6">
          <h1 class="text-2xl font-bold text-gray-900 mb-6">{pageTitle}</h1>
          
          <form id="hotelForm" class="space-y-8">
            <!-- General Information Section -->
            <div>
              <h2 class="text-xl font-semibold text-gray-800 mb-4">General Information</h2>
              <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                <div>
                  <label for="hotelName" class="block text-sm font-medium text-gray-700 mb-1">Hotel Name</label>
                  <input type="text" id="hotelName" name="hotelName" value={hotel.name} class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-primary-green focus:border-primary-green">
                </div>
                <div>
                  <label for="hotelAddress" class="block text-sm font-medium text-gray-700 mb-1">Address</label>
                  <input type="text" id="hotelAddress" name="hotelAddress" value={hotel.address} class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-primary-green focus:border-primary-green">
                </div>
              </div>
            </div>
            
            <!-- Description Section -->
            <div>
              <h2 class="text-xl font-semibold text-gray-800 mb-4">Description</h2>
              <textarea id="hotelDescription" name="hotelDescription" rows="6" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-primary-green focus:border-primary-green">{hotel.description}</textarea>
              <p class="mt-2 text-sm text-gray-500">Describe your hotel, its surroundings, and what makes it special.</p>
            </div>
            
            <!-- Contact Information Section -->
            <div>
              <h2 class="text-xl font-semibold text-gray-800 mb-4">Contact Information</h2>
              <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                <div>
                  <label for="hotelEmail" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                  <input type="email" id="hotelEmail" name="hotelEmail" value={hotel.email} class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-primary-green focus:border-primary-green">
                </div>
                <div>
                  <label for="hotelPhone" class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
                  <input type="tel" id="hotelPhone" name="hotelPhone" value={hotel.phone} class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-primary-green focus:border-primary-green">
                </div>
              </div>
            </div>
            
            <!-- Amenities Section -->
            <div>
              <h2 class="text-xl font-semibold text-gray-800 mb-4">Amenities</h2>
              <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3">
                {hotel.amenities.map((amenity, index) => (
                  <div class="flex items-center">
                    <input 
                      type="checkbox" 
                      id={`amenity-${index}`} 
                      name={`amenity-${index}`} 
                      checked={amenity.enabled}
                      class="h-4 w-4 text-primary-green focus:ring-primary-green border-gray-300 rounded"
                    >
                    <label for={`amenity-${index}`} class="ml-2 block text-sm text-gray-700">
                      {amenity.name}
                    </label>
                  </div>
                ))}
              </div>
            </div>
            
            <!-- Images Section -->
            <div>
              <h2 class="text-xl font-semibold text-gray-800 mb-4">Hotel Images</h2>
              <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3">
                {hotel.images.map((image, index) => (
                  <div class="relative rounded-lg overflow-hidden bg-gray-100 aspect-video">
                    <img src={image} alt={`Hotel image ${index + 1}`} class="w-full h-full object-cover">
                    <button type="button" class="absolute top-2 right-2 bg-secondary-brown text-white rounded-full p-1 hover:bg-secondary-brown hover:brightness-90" data-index={index}>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                      </svg>
                    </button>
                  </div>
                ))}
                <div class="border-2 border-dashed border-gray-300 rounded-lg aspect-video flex flex-col items-center justify-center cursor-pointer hover:border-primary-green hover:bg-secondary-green2 bg-opacity-10" id="uploadImageBox">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                  <span class="mt-2 text-sm text-gray-500">Add Image</span>
                  <input type="file" id="imageUpload" name="imageUpload" accept="image/*" class="hidden">
                </div>
              </div>
              <p class="mt-2 text-sm text-gray-500">Upload high-quality images of your hotel. The first image will be used as the main image.</p>
            </div>
            
            <!-- Form Actions -->
            <div class="flex justify-end space-x-4">
              <a href="/dashboard" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50">
                Cancel
              </a>
              <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-primary-green border border-transparent rounded-md hover:bg-primary-green focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-green">
                {isNewHotel ? 'Create Hotel' : 'Save Changes'}
              </button>
            </div>
          </form>
        </div>
      </div>
    </main>
  </div>
</MainLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Image upload handling
    const uploadBox = document.getElementById('uploadImageBox');
    const fileInput = document.getElementById('imageUpload');
    
    if (uploadBox && fileInput) {
      uploadBox.addEventListener('click', () => {
        fileInput.click();
      });
      
      fileInput.addEventListener('change', (event) => {
        if (event.target instanceof HTMLInputElement && event.target.files && event.target.files.length > 0) {
          // In a real application, you would handle file upload to server
          console.log('File selected:', event.target.files[0].name);
          // You could preview the image here before upload
        }
      });
    }
    
    // Form submission
    const form = document.getElementById('hotelForm');
    if (form) {
      form.addEventListener('submit', (event) => {
        event.preventDefault();
        
        // Collect form data
        const formData = new FormData(form as HTMLFormElement);
        
        // In a real application, you would send this data to your backend
        console.log('Form submitted');
        
        // Redirect back to dashboard after successful submission
        // window.location.href = '/dashboard';
      });
    }
    
    // Delete image buttons
    const deleteButtons = document.querySelectorAll('button[data-index]');
    deleteButtons.forEach((button) => {
      button.addEventListener('click', (event) => {
        const index = (event.currentTarget as HTMLButtonElement).dataset.index;
        if (index) {
          // In a real application, you would update your image array
          console.log(`Delete image at index ${index}`);
          // And probably remove the element from the DOM
        }
      });
    });
  });
</script> 