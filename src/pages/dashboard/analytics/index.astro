---
import DashBoardLayout from "@/layouts/DashBoardLayout.astro";

// Mock data for IoT devices statistics
const deviceStats = {
  totalDevices: 48,
  activeDevices: 42,
  inactiveDevices: 4,
  maintenanceDevices: 2,
  averageUptime: 98.7,
  averageResponseTime: 0.8
};

// Data for temperature chart (mock data)
const temperatureData = {
  labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
  datasets: [22, 23, 25, 24, 26, 28, 29, 30, 28, 26, 24, 23]
};

// Data for humidity chart (mock data)
const humidityData = {
  labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
  datasets: [45, 48, 52, 55, 60, 65, 63, 58, 55, 50, 46, 44]
};

// Data for energy consumption chart (mock data)
const energyData = {
  labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
  datasets: [320, 310, 300, 305, 315, 350, 380, 375, 340, 330, 320, 325]
};

// Device types distribution
const deviceTypes = [
  { type: 'Temperature Sensors', count: 18, color: 'rgb(255, 99, 132)' },
  { type: 'Lighting Controls', count: 12, color: 'rgb(54, 162, 235)' },
  { type: 'Security Devices', count: 8, color: 'rgb(255, 206, 86)' },
  { type: 'Smart Locks', count: 6, color: 'rgb(75, 192, 192)' },
  { type: 'HVAC Controls', count: 4, color: 'rgb(153, 102, 255)' }
];

// Device alerts in the last 30 days
const recentAlerts = [
  { id: 1, device: 'Temperature Sensor #103', room: 'Room 005', alert: 'Temperature above threshold', timestamp: '2025-05-14T08:23:15' },
  { id: 2, device: 'Smart Lock #208', room: 'Room 002', alert: 'Failed unlock attempt', timestamp: '2025-05-13T22:45:32' },
  { id: 3, device: 'HVAC Control #056', room: 'Room 008', alert: 'Maintenance required', timestamp: '2025-05-10T14:12:08' },
  { id: 4, device: 'Motion Sensor #312', room: 'Room 001', alert: 'Battery low', timestamp: '2025-05-09T19:37:22' }
];

// Format date function
function formatDate(dateString: string) {
  const date = new Date(dateString);
  return date.toLocaleString('es-ES', { 
    year: 'numeric', 
    month: 'short', 
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
}
---

<DashBoardLayout title="Analytics - SmartSuite">
    <h1 class="text-3xl font-bold text-gray-900 mb-4">Analytics</h1>
    
    <!-- Overview Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Total Devices Card -->
      <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center justify-between">
          <h3 class="text-lg font-medium text-gray-900">Total Devices</h3>
          <span class="bg-blue-100 text-blue-800 rounded-full px-3 py-1 text-sm font-semibold">
            All
          </span>
        </div>
        <p class="text-3xl font-bold mt-4">{deviceStats.totalDevices}</p>
        <div class="flex items-center justify-between mt-4">
          <div class="flex items-center">
            <div class="h-3 w-3 rounded-full bg-green-500 mr-2"></div>
            <span class="text-sm text-gray-600">Active: {deviceStats.activeDevices}</span>
          </div>
          <div class="flex items-center">
            <div class="h-3 w-3 rounded-full bg-red-500 mr-2"></div>
            <span class="text-sm text-gray-600">Inactive: {deviceStats.inactiveDevices}</span>
          </div>
          <div class="flex items-center">
            <div class="h-3 w-3 rounded-full bg-yellow-500 mr-2"></div>
            <span class="text-sm text-gray-600">Maintenance: {deviceStats.maintenanceDevices}</span>
          </div>
        </div>
      </div>
      
      <!-- Average Uptime Card -->
      <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center justify-between">
          <h3 class="text-lg font-medium text-gray-900">Average Uptime</h3>
          <span class="bg-green-100 text-green-800 rounded-full px-3 py-1 text-sm font-semibold">
            Last 30 days
          </span>
        </div>
        <p class="text-3xl font-bold mt-4">{deviceStats.averageUptime}%</p>
        <div class="w-full bg-gray-200 rounded-full h-2.5 mt-4">
          <div class="bg-green-600 h-2.5 rounded-full" style={`width: ${deviceStats.averageUptime}%`}></div>
        </div>
      </div>
      
      <!-- Response Time Card -->
      <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center justify-between">
          <h3 class="text-lg font-medium text-gray-900">Avg. Response Time</h3>
          <span class="bg-purple-100 text-purple-800 rounded-full px-3 py-1 text-sm font-semibold">
            Real-time
          </span>
        </div>
        <p class="text-3xl font-bold mt-4">{deviceStats.averageResponseTime}s</p>
        <div class="text-sm text-gray-500 mt-4">Optimal performance &lt; 1s</div>
      </div>
    </div>
    
    <!-- Charts Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Temperature Chart -->
      <div class="bg-white rounded-lg shadow p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Average Temperature</h3>
        <div class="h-80">
          <canvas id="temperatureChart"></canvas>
        </div>
      </div>
      
      <!-- Humidity Chart -->
      <div class="bg-white rounded-lg shadow p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Average Humidity</h3>
        <div class="h-80">
          <canvas id="humidityChart"></canvas>
        </div>
      </div>
      
      <!-- Energy Consumption Chart -->
      <div class="bg-white rounded-lg shadow p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Energy Consumption (kWh)</h3>
        <div class="h-80">
          <canvas id="energyChart"></canvas>
        </div>
      </div>
      
      <!-- Device Type Distribution -->
      <div class="bg-white rounded-lg shadow p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Device Type Distribution</h3>
        <div class="h-80">
          <canvas id="deviceDistributionChart"></canvas>
        </div>
      </div>
    </div>
    
    <!-- Recent Alerts -->
    <div class="bg-white rounded-lg shadow p-6">
      <h3 class="text-lg font-medium text-gray-900 mb-4">Recent Alerts</h3>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Device</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Room</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Alert</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Time</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            {recentAlerts.map(alert => (
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">{alert.device}</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{alert.room}</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{alert.alert}</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{formatDate(alert.timestamp)}</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <a href="#" class="text-primary-green hover:text-secondary-green1">View Details</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
</DashBoardLayout>

<script>
  // Import Chart.js
  import Chart from 'chart.js/auto';
  
  // Wait for DOM to be fully loaded
  document.addEventListener('DOMContentLoaded', () => {
    // Temperature Chart
    const temperatureCtx = document.getElementById('temperatureChart') as HTMLCanvasElement | null;
    if (temperatureCtx) {
      new Chart(temperatureCtx, {
        type: 'line',
        data: {
          labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
          datasets: [{
            label: 'Average Temperature (°C)',
            data: [22, 23, 25, 24, 26, 28, 29, 30, 28, 26, 24, 23],
            borderColor: 'rgb(255, 99, 132)',
            backgroundColor: 'rgba(255, 99, 132, 0.2)',
            tension: 0.3,
            fill: true
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'top',
            }
          },
          scales: {
            y: {
              beginAtZero: false,
              min: 15,
              max: 35,
              ticks: {
                stepSize: 5
              }
            }
          }
        }
      });
    }
    
    // Humidity Chart
    const humidityCtx = document.getElementById('humidityChart') as HTMLCanvasElement | null;
    if (humidityCtx) {
      new Chart(humidityCtx, {
        type: 'line',
        data: {
          labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
          datasets: [{
            label: 'Average Humidity (%)',
            data: [45, 48, 52, 55, 60, 65, 63, 58, 55, 50, 46, 44],
            borderColor: 'rgb(54, 162, 235)',
            backgroundColor: 'rgba(54, 162, 235, 0.2)',
            tension: 0.3,
            fill: true
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'top',
            }
          },
          scales: {
            y: {
              beginAtZero: false,
              min: 30,
              max: 80,
              ticks: {
                stepSize: 10
              }
            }
          }
        }
      });
    }
    
    // Energy Consumption Chart
    const energyCtx = document.getElementById('energyChart') as HTMLCanvasElement | null;
    if (energyCtx) {
      new Chart(energyCtx, {
        type: 'bar',
        data: {
          labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
          datasets: [{
            label: 'Energy Consumption (kWh)',
            data: [320, 310, 300, 305, 315, 350, 380, 375, 340, 330, 320, 325],
            backgroundColor: 'rgba(75, 192, 192, 0.6)',
            borderColor: 'rgb(75, 192, 192)',
            borderWidth: 1
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'top',
            }
          },
          scales: {
            y: {
              beginAtZero: false,
              min: 250,
              max: 400
            }
          }
        }
      });
    }
    
    // Device Distribution Chart (Doughnut)
    const deviceDistributionCtx = document.getElementById('deviceDistributionChart') as HTMLCanvasElement | null;
    if (deviceDistributionCtx) {
      new Chart(deviceDistributionCtx, {
        type: 'doughnut',
        data: {
          labels: ['Temperature Sensors', 'Lighting Controls', 'Security Devices', 'Smart Locks', 'HVAC Controls'],
          datasets: [{
            label: 'Device Count',
            data: [18, 12, 8, 6, 4],
            backgroundColor: [
              'rgb(255, 99, 132)',
              'rgb(54, 162, 235)',
              'rgb(255, 206, 86)',
              'rgb(75, 192, 192)',
              'rgb(153, 102, 255)'
            ],
            borderWidth: 1
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'right',
            }
          }
        }
      });
    }
  });
</script>