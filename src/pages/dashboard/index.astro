---
import DashBoardLayout from "@/layouts/DashBoardLayout.astro";
import RouteGuard from "@/components/RouteGuard.astro";
import { Roles } from "@/config/routesConfig";

// Mock hotel data for demonstration
const hotels = [
  {
    id: 1,
    name: "Royal Decameron Punta Sal",
    address: "Av. Panamericana N, Punta Sal 24560",
    description: "This vibrant all-inclusive hotel is nestled among palm trees on Punta Sal Beach, 5 km from the town center and 89 km from Tumbes Airport. Simple rooms feature a terrace or balcony, flat-screen TV, and internet access (chargeable); some have a sitting area. Free amenities include water sports, evening entertainment, and beach equipment rentals, plus meals and drinks served at 3 restaurants and 5 bars. Other amenities include a lively nightclub, gardens, and a long beach with cabanas. There's also an outdoor pool, a whirlpool, and a gym.",
    email: "bookings@decameron.com",
    phone: "073 55 4877",
    amenities: [
      { name: "Paid Wi-Fi", icon: "wifi" },
      { name: "Breakfast included", icon: "coffee" },
      { name: "Free parking", icon: "car" },
      { name: "Outdoor pool", icon: "water" }
    ],
    images: [
      "/hotel1-aerial.jpg",
      "/hotel1-room.jpg",
      "/hotel1-beach.jpg"
    ]
  }
];
---

<DashBoardLayout title="Dashboard - Smart Suite">
  <div class="flex flex-wrap items-center justify-between mb-6">
      {hotels.map((hotel) => (
        <div class="bg-white shadow rounded-lg overflow-hidden mb-8">
          <div class="p-6">
            <h2 class="text-2xl font-bold text-gray-900 mb-2">{hotel.name}</h2>
            <p class="text-gray-600 mb-6">{hotel.address}</p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div>
                <div class="flex justify-between items-center mb-4">
                  <h3 class="text-lg font-medium text-gray-900">Discover how everyone see your hotel</h3>
                  <a href={`/dashboard/hotel/${hotel.id}`} class="text-primary-green hover:text-primary-green flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
                      <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"></path>
                    </svg>
                    Edit
                  </a>
                </div>
                <p class="text-gray-700 mb-6">{hotel.description}</p>

                <div class="space-y-4">
                  {hotel.amenities.map((amenity) => (
                    <div class="flex items-center">
                      <span class="flex-shrink-0 h-5 w-5 text-primary-green mr-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                      </span>
                      <span class="text-gray-700">{amenity.name}</span>
                    </div>
                  ))}
                </div>
              </div>

              <div>
                <div class="mb-6">
                  <div class="flex justify-between items-center mb-2">
                    <h3 class="text-lg font-medium text-gray-900">Email</h3>
                    <a href={`/dashboard/hotel/${hotel.id}`} class="text-primary-green hover:text-primary-green flex items-center">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"></path>
                      </svg>
                      Edit
                    </a>
                  </div>
                  <p class="text-gray-700">{hotel.email}</p>
                </div>

                <div>
                  <div class="flex justify-between items-center mb-2">
                    <h3 class="text-lg font-medium text-gray-900">Phone Number</h3>
                    <a href={`/dashboard/hotel/${hotel.id}`} class="text-primary-green hover:text-primary-green flex items-center">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"></path>
                      </svg>
                      Edit
                    </a>
                  </div>
                  <p class="text-gray-700">{hotel.phone}</p>
                </div>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-3 gap-4 p-4 bg-gray-50">
            {hotel.images.map((image, index) => (
              <div class={`${index === 0 ? "col-span-2 row-span-2" : ""} aspect-video rounded-lg overflow-hidden bg-gray-200`}>
                <img src={image} alt={`${hotel.name} - Image ${index + 1}`} class="w-full h-full object-cover" />
              </div>
            ))}
          </div>
        </div>
      ))}

      <!-- Add New Hotel Button -->
      <div class="mt-8 flex justify-center">
        <a href="/dashboard/hotel/new" class="px-6 py-3 bg-primary-green text-black rounded-md hover:bg-primary-green flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"></path>
          </svg>
          Add New Hotel
        </a>
      </div>
    </div>
</DashBoardLayout>

<script>
  // Add JavaScript for interactive elements here
  document.addEventListener('DOMContentLoaded', () => {
    // No need for edit button event listeners since they're now links
    // Any other dashboard interactions can be added here
  });
</script> 