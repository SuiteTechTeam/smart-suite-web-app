---
import DashBoardLayout from "@/layouts/DashBoardLayout.astro";

// In a real application, you would check authentication
const isAuthenticated = true;
const userRole = "owner";

if (!isAuthenticated) {
  return Astro.redirect("/sign-in");
}

if (userRole !== "owner") {
  return Astro.redirect("/");
}

// Mock room data for demonstration
const rooms = [
  {
    id: 1,
    name: "Deluxe Ocean View",
    roomNumber: "301",
    hotelId: 1,
    hotelName: "Royal Decameron Punta Sal",
    capacity: 2,
    bedType: "King",
    pricePerNight: 150,
    status: "available", // available, occupied, maintenance
    amenities: [
      { name: "Air Conditioning", icon: "snowflake" },
      { name: "Mini Bar", icon: "glass-martini" },
      { name: "Flat-screen TV", icon: "tv" },
      { name: "Ocean View", icon: "water" }
    ],
    connected_devices: [
      { id: 1, name: "Smart Thermostat", type: "climate", status: "active" },
      { id: 2, name: "Smart Light", type: "lighting", status: "active" },
      { id: 3, name: "Smart Lock", type: "security", status: "active" }
    ],
    image: "/hotel1-room.jpg"
  },
  {
    id: 2,
    name: "Standard Garden View",
    roomNumber: "102",
    hotelId: 1,
    hotelName: "Royal Decameron Punta Sal",
    capacity: 2,
    bedType: "Twin",
    pricePerNight: 100,
    status: "occupied",
    amenities: [
      { name: "Air Conditioning", icon: "snowflake" },
      { name: "Flat-screen TV", icon: "tv" },
      { name: "Garden View", icon: "leaf" }
    ],
    connected_devices: [
      { id: 4, name: "Smart Thermostat", type: "climate", status: "active" },
      { id: 5, name: "Smart Light", type: "lighting", status: "inactive" }
    ],
    image: "/hotel1-room.jpg"
  },
  {
    id: 3,
    name: "Family Suite",
    roomNumber: "401",
    hotelId: 1,
    hotelName: "Royal Decameron Punta Sal",
    capacity: 4,
    bedType: "2 Queen",
    pricePerNight: 220,
    status: "maintenance",
    amenities: [
      { name: "Air Conditioning", icon: "snowflake" },
      { name: "Mini Bar", icon: "glass-martini" },
      { name: "Flat-screen TV", icon: "tv" },
      { name: "Balcony", icon: "door-open" },
      { name: "Kitchenette", icon: "utensils" }
    ],
    connected_devices: [
      { id: 6, name: "Smart Thermostat", type: "climate", status: "maintenance" },
      { id: 7, name: "Smart Light", type: "lighting", status: "active" },
      { id: 8, name: "Smart Lock", type: "security", status: "maintenance" }
    ],
    image: "/hotel1-room.jpg"
  }
];

// Status colors
const statusColors = {
  available: "bg-green-100 text-green-800",
  occupied: "bg-blue-100 text-blue-800",
  maintenance: "bg-yellow-100 text-yellow-800"
};

// Status icons
const statusIcons = {
  available: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
  </svg>`,
  occupied: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v2H7a1 1 0 100 2h2v2a1 1 0 102 0v-2h2a1 1 0 100-2h-2V7z" clip-rule="evenodd" />
  </svg>`,
  maintenance: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm-1-9a1 1 0 011-1h2a1 1 0 110 2h-2a1 1 0 01-1-1zm-2-3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd" />
  </svg>`
};

// Device type icons
const deviceIcons = {
  climate: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
    <path d="M10 2a8 8 0 100 16 8 8 0 000-16zm0 14a6 6 0 110-12 6 6 0 010 12z" />
    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
  </svg>`,
  lighting: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
    <path d="M11 3a1 1 0 10-2 0v1a1 1 0 102 0V3zM15.657 5.757a1 1 0 00-1.414-1.414l-.707.707a1 1 0 001.414 1.414l.707-.707zM18 10a1 1 0 01-1 1h-1a1 1 0 110-2h1a1 1 0 011 1zM5.05 6.464A1 1 0 106.464 5.05l-.707-.707a1 1 0 00-1.414 1.414l.707.707zM5 10a1 1 0 01-1 1H3a1 1 0 110-2h1a1 1 0 011 1zM8 16v-1h4v1a2 2 0 11-4 0zM12 14c.015-.34.208-.646.477-.859a4 4 0 10-4.954 0c.27.213.462.519.476.859h4.002z" />
  </svg>`,
  security: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
    <path fill-rule="evenodd" d="M10 1.944A11.954 11.954 0 012.166 5C2.056 5.157 2 5.54 2 6.0v3.443c0 .884.126 1.756.372 2.589a7.8 7.8 0 001.81 3.058A7.9 7.9 0 0010 18.354a7.9 7.9 0 005.818-3.264 7.8 7.8 0 001.81-3.058A8.742 8.742 0 0018 9.442V6c0-.46-.056-.843-.166-1A11.954 11.954 0 0110 1.944zm5 8.416L9 12.223 6 10.36V5.127a10.002 10.002 0 014-1.142c1.42 0 2.77.292 4 .823v5.552z" clip-rule="evenodd" />
  </svg>`
};

// Device status colors
const deviceStatusColors = {
  active: "text-green-500",
  inactive: "text-gray-500",
  maintenance: "text-yellow-500"
};
---

<DashBoardLayout title="Rooms - SmartSuite">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Page Header -->
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-3xl font-bold text-gray-900">Room Management</h1>
      <a href="/dashboard/rooms/new" class="px-4 py-2 bg-primary-green text-white rounded-md hover:bg-primary-green flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"></path>
        </svg>
        Add New Room
      </a>
    </div>

    <!-- Filter Section -->
    <div class="bg-white shadow rounded-lg p-6 mb-8">
      <div class="flex flex-col md:flex-row md:items-center gap-4">
        <div class="flex-1">
          <label for="hotelFilter" class="block text-sm font-medium text-gray-700 mb-1">Hotel</label>
          <select id="hotelFilter" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-primary-green focus:border-primary-green">
            <option value="all">All Hotels</option>
            <option value="1" selected>Royal Decameron Punta Sal</option>
            <!-- More hotels would be populated here -->
          </select>
        </div>
        <div class="flex-1">
          <label for="statusFilter" class="block text-sm font-medium text-gray-700 mb-1">Status</label>
          <select id="statusFilter" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-primary-green focus:border-primary-green">
            <option value="all">All Statuses</option>
            <option value="available">Available</option>
            <option value="occupied">Occupied</option>
            <option value="maintenance">Maintenance</option>
          </select>
        </div>
        <div class="flex-1">
          <label for="searchRoom" class="block text-sm font-medium text-gray-700 mb-1">Search</label>
          <input type="text" id="searchRoom" placeholder="Room number or name" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-primary-green focus:border-primary-green">
        </div>
      </div>
    </div>

    <!-- Rooms Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {rooms.map((room) => (
        <div class="bg-white shadow rounded-lg overflow-hidden">
          <div class="relative">
            <img src={room.image} alt={room.name} class="w-full h-48 object-cover">
            <div class={`absolute top-4 right-4 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${statusColors[room.status as keyof typeof statusColors]}`}>
              <Fragment set:html={statusIcons[room.status as keyof typeof statusIcons]} />
              {room.status.charAt(0).toUpperCase() + room.status.slice(1)}
            </div>
          </div>
          
          <div class="p-6">
            <div class="flex justify-between items-start mb-4">
              <div>
                <h2 class="text-xl font-bold text-gray-900">{room.name}</h2>
                <p class="text-gray-500">Room {room.roomNumber}</p>
              </div>
              <span class="text-xl font-bold text-primary-green">${room.pricePerNight}<span class="text-sm font-normal text-gray-500">/night</span></span>
            </div>
            
            <div class="flex items-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400 mr-2" viewBox="0 0 20 20" fill="currentColor">
                <path d="M7 3a1 1 0 000 2h6a1 1 0 100-2H7zM4 7a1 1 0 011-1h10a1 1 0 110 2H5a1 1 0 01-1-1zM2 11a2 2 0 012-2h12a2 2 0 012 2v4a2 2 0 01-2 2H4a2 2 0 01-2-2v-4z" />
              </svg>
              <span class="text-gray-700">{room.bedType} • Max {room.capacity} guests</span>
            </div>
            
            <div class="mb-4">
              <h3 class="text-sm font-medium text-gray-900 mb-2">Amenities</h3>
              <div class="flex flex-wrap gap-2">
                {room.amenities.map((amenity) => (
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                    {amenity.name}
                  </span>
                ))}
              </div>
            </div>
            
            <div class="mb-4">
              <h3 class="text-sm font-medium text-gray-900 mb-2">Connected Devices</h3>
              <div class="space-y-2">
                {room.connected_devices.map((device) => (
                  <div class="flex items-center justify-between">
                    <div class="flex items-center">
                      <span class={`flex-shrink-0 h-5 w-5 ${deviceStatusColors[device.status as keyof typeof deviceStatusColors]} mr-2`} set:html={deviceIcons[device.type as keyof typeof deviceIcons]} />
                      <span class="text-sm text-gray-700">{device.name}</span>
                    </div>
                    <span class={`text-xs font-medium ${deviceStatusColors[device.status as keyof typeof deviceStatusColors]}`}>
                      {device.status.charAt(0).toUpperCase() + device.status.slice(1)}
                    </span>
                  </div>
                ))}
              </div>
            </div>
            
            <div class="flex justify-between mt-6">
              <a href={`/dashboard/rooms/${room.id}`} class="text-primary-green hover:text-primary-green flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"></path>
                </svg>
                Edit
              </a>
              <button class="text-secondary-brown hover:text-secondary-brown flex items-center" data-room-id={room.id}>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                </svg>
                Delete
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</DashBoardLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Filter functionality
    const hotelFilter = document.getElementById('hotelFilter');
    const statusFilter = document.getElementById('statusFilter');
    const searchInput = document.getElementById('searchRoom');
    
    const applyFilters = () => {
      // In a real app, you would filter the rooms displayed or reload from the server
      console.log('Filters applied:', {
        hotel: (hotelFilter as HTMLSelectElement | null)?.value,
        status: (statusFilter as HTMLSelectElement | null)?.value,
        search: (searchInput as HTMLInputElement | null)?.value
      });
    };
    
    hotelFilter?.addEventListener('change', applyFilters);
    statusFilter?.addEventListener('change', applyFilters);
    searchInput?.addEventListener('input', () => {
      // Debounce implementation would be better in a real app
      setTimeout(applyFilters, 300);
    });
    
    // Delete Room buttons
    const deleteButtons = document.querySelectorAll('button[data-room-id]');
    deleteButtons.forEach((button) => {
      button.addEventListener('click', (event) => {
        const roomId = (event.currentTarget as HTMLButtonElement).dataset.roomId;
        if (roomId) {
          if (confirm('Are you sure you want to delete this room? This action cannot be undone.')) {
            // In a real application, you would call an API to delete the room
            console.log(`Delete room with ID ${roomId}`);
            // Then maybe remove from the DOM or reload
          }
        }
      });
    });
  });
</script>