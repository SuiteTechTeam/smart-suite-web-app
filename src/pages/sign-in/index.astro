---
import MainLayout from "@/layouts/MainLayout.astro";
import { Eye, EyeOff, Github } from "@lucide/astro";

if (Astro.locals.isAuthenticated) {
  return Astro.redirect('/');
}

// Acceder a la información del usuario si es necesario
const user = Astro.locals.user;
---

<MainLayout title="Login">
  <div class="min-h-screen flex">
    <!-- Lado izquierdo - Formulario -->
    <div class="w-full lg:w-1/2 flex items-center justify-center bg-white p-8">
      <div class="max-w-md w-full space-y-8">
        <!-- Logo -->
        <div class="flex flex-col items-center">
          <div class="w-16 h-16 rounded-full bg-primary-green flex items-center justify-center">
              <img src="/smart-suite-logo.png" alt="Logo" class="h-14 w-14 border-2 border-white rounded-full">
          </div>
          <h1 class="mt-6 text-center text-3xl font-bold text-gray-900">Welcome!</h1>
          <p class="mt-2 text-center text-gray-600">Enter your credentials to access to your account</p>
        </div>
        
        <!-- Formulario -->
        <form class="mt-8 space-y-6" id="loginForm">
          <div class="space-y-4">
            <div>
              <label for="email" class="sr-only">Username</label>
              <input id="email" name="email" type="email" required
                class="appearance-none relative block w-full px-3 py-3 border border-gray-300 rounded-md placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-primary-green focus:border-primary-green sm:text-sm"
                placeholder="Username">
            </div>
            
            <div class="relative">
              <label for="password" class="sr-only">Password</label>
              <input id="password" name="password" type="password" required
                class="appearance-none relative block w-full px-3 py-3 border border-gray-300 rounded-md placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-primary-green focus:border-primary-green sm:text-sm"
                placeholder="Password">
              <button type="button" id="togglePassword" class="absolute inset-y-0 right-0 pr-3 flex items-center">
                <Eye class="h-5 w-5 text-gray-400" />
                <EyeOff class="h-5 w-5 text-gray-400 hidden" />
              </button>
            </div>
            
            <div>
              <label for="role" class="sr-only">Role</label>
              <select id="role" name="role" required
                class="appearance-none relative block w-full px-3 py-3 border border-gray-300 rounded-md placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-primary-green focus:border-primary-green sm:text-sm">
                <option value="">Select a role</option>
                <option value="1">Owner</option>
                <option value="2">Admin</option>
                <option value="3">Worker</option>
              </select>
            </div>
          </div>

          <div class="flex items-center justify-end">
            <a href="#" class="text-sm text-primary-green hover:text-primary-green">Forgot Password</a>
          </div>

          <div id="errorMessage" class="hidden text-secondary-brown text-sm text-center"></div>

          <div>
            <button type="submit" id="submitButton"
              class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 hover:text-black focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-green">
              <span id="buttonText">Login</span>
              <span id="loadingSpinner" class="hidden">
                <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
              </span>
            </button>
          </div>
        </form>

        <!-- Separador -->
        <div class="mt-6">
          <div class="relative">
            <div class="absolute inset-0 flex items-center">
              <div class="w-full border-t border-gray-300"></div>
            </div>
            <div class="relative flex justify-center text-sm">
              <span class="px-2 bg-white text-gray-500">or continue with</span>
            </div>
          </div>
        </div>

        <!-- Botones sociales -->
        <div class="mt-6 flex justify-center items-center">
          <button type="button" class="flex justify-center items-center py-2 px-4 border border-gray-300 rounded-md shadow-sm bg-white hover:bg-gray-50">
            <img src="/github.svg" alt="GitHub" class="h-5 w-5 text-gray-700">
          </button>
        </div>

        <!-- Enlace para crear cuenta -->
        <div class="mt-6 text-center">
          <p class="text-sm text-gray-600">Don't have an account yet? <a href="/sign-up" class="text-primary-green hover:text-primary-green font-medium">Create Account</a></p>
        </div>
      </div>
    </div>

    <!-- Lado derecho - Imagen de fondo -->
    <div class="hidden lg:block w-1/2 bg-cover bg-center" style="background-image: url('/images/smart-hotel-image.png'); blur(5px);">
    </div>
  </div>
</MainLayout>

<script>
  import { authService } from '@/services/auth.service';

  const form = document.getElementById('loginForm') as HTMLFormElement;
  const submitButton = document.getElementById('submitButton') as HTMLButtonElement;
  const buttonText = document.getElementById('buttonText') as HTMLSpanElement;
  const loadingSpinner = document.getElementById('loadingSpinner') as HTMLSpanElement;
  const errorMessage = document.getElementById('errorMessage') as HTMLDivElement;
  
  // Toggle password visibility
  const togglePassword = document.getElementById('togglePassword');
  const passwordInput = document.getElementById('password') as HTMLInputElement;
  const eyeIcon = togglePassword?.querySelector('svg:first-child');
  const eyeOffIcon = togglePassword?.querySelector('svg:last-child');
  
  togglePassword?.addEventListener('click', () => {
    if (passwordInput.type === 'password') {
      passwordInput.type = 'text';
      eyeIcon?.classList.add('hidden');
      eyeOffIcon?.classList.remove('hidden');
    } else {
      passwordInput.type = 'password';
      eyeIcon?.classList.remove('hidden');
      eyeOffIcon?.classList.add('hidden');
    }
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Mostrar estado de carga
    submitButton.disabled = true;
    buttonText.classList.add('hidden');
    loadingSpinner.classList.remove('hidden');
    errorMessage.classList.add('hidden');

    const email = (form.elements.namedItem('email') as HTMLInputElement).value;
    const password = (form.elements.namedItem('password') as HTMLInputElement).value;
    const rolesId = parseInt((form.elements.namedItem('role') as HTMLSelectElement).value);

    try {
      await authService.login({ email, password, rolesId });
      window.location.href = '/';
    } catch (error) {
      errorMessage.textContent = 'Login failed. Please check your credentials.';
      errorMessage.classList.remove('hidden');
      
      // Restaurar estado del botón
      submitButton.disabled = false;
      buttonText.classList.remove('hidden');
      loadingSpinner.classList.add('hidden');
    }
  });
</script> 