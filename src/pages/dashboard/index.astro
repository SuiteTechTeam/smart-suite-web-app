---
import MainLayout from "@/layouts/MainLayout.astro";

// In a real application, you would check authentication
// This is a placeholder for demonstration
const isAuthenticated = true;
const userRole = "owner";

if (!isAuthenticated) {
  return Astro.redirect("/sign-in");
}

if (userRole !== "owner") {
  return Astro.redirect("/");
}

// Mock hotel data for demonstration
const hotels = [
  {
    id: 1,
    name: "Royal Decameron Punta Sal",
    address: "Av. Panamericana N, Punta Sal 24560",
    description: "This vibrant all-inclusive hotel is nestled among palm trees on Punta Sal Beach, 5 km from the town center and 89 km from Tumbes Airport. Simple rooms feature a terrace or balcony, flat-screen TV, and internet access (chargeable); some have a sitting area. Free amenities include water sports, evening entertainment, and beach equipment rentals, plus meals and drinks served at 3 restaurants and 5 bars. Other amenities include a lively nightclub, gardens, and a long beach with cabanas. There's also an outdoor pool, a whirlpool, and a gym.",
    email: "bookings@decameron.com",
    phone: "073 55 4877",
    amenities: [
      { name: "Paid Wi-Fi", icon: "wifi" },
      { name: "Breakfast included", icon: "coffee" },
      { name: "Free parking", icon: "car" },
      { name: "Outdoor pool", icon: "water" }
    ],
    images: [
      "/hotel1-aerial.jpg",
      "/hotel1-room.jpg",
      "/hotel1-beach.jpg"
    ]
  }
];
---

<MainLayout title="Dashboard - Smart Suite">
  <div class="min-h-screen bg-gray-50">
    <!-- Navigation Header -->
    <header class="bg-white shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center h-16">
        <div class="flex items-center">
          <a href="/" class="flex items-center text-primary-green font-bold text-xl">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
            Smart Suite
          </a>
        </div>
        <div class="flex items-center">
          <button class="mr-4 relative">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
            </svg>
          </button>
          <span class="mr-4">ES</span>
          <button class="h-10 w-10 rounded-full bg-gray-500 flex items-center justify-center text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Navigation Tabs -->
      <div class="border-b border-gray-200 mb-8">
        <nav class="-mb-px flex space-x-8">
          <a href="#" class="border-b-2 border-primary-green text-primary-green pb-4 px-1 text-sm font-medium flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
            </svg>
            Overview
          </a>
          <a href="#" class="text-gray-500 hover:text-gray-700 pb-4 px-1 text-sm font-medium flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
            Analytics
          </a>
          <a href="#" class="text-gray-500 hover:text-gray-700 pb-4 px-1 text-sm font-medium flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
            Providers
          </a>
          <a href="#" class="text-gray-500 hover:text-gray-700 pb-4 px-1 text-sm font-medium flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
            </svg>
            Inventory
          </a>
          <a href="#" class="text-gray-500 hover:text-gray-700 pb-4 px-1 text-sm font-medium flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
            </svg>
            Rooms
          </a>
          <a href="#" class="text-gray-500 hover:text-gray-700 pb-4 px-1 text-sm font-medium flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
            Organization
          </a>
          <a href="#" class="text-gray-500 hover:text-gray-700 pb-4 px-1 text-sm font-medium flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            Devices
          </a>
        </nav>
      </div>

      {hotels.map((hotel) => (
        <div class="bg-white shadow rounded-lg overflow-hidden mb-8">
          <div class="p-6">
            <h2 class="text-2xl font-bold text-gray-900 mb-2">{hotel.name}</h2>
            <p class="text-gray-600 mb-6">{hotel.address}</p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div>
                <div class="flex justify-between items-center mb-4">
                  <h3 class="text-lg font-medium text-gray-900">Discover how everyone see your hotel</h3>
                  <a href={`/dashboard/hotel/${hotel.id}`} class="text-primary-green hover:text-primary-green flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
                      <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"></path>
                    </svg>
                    Edit
                  </a>
                </div>
                <p class="text-gray-700 mb-6">{hotel.description}</p>

                <div class="space-y-4">
                  {hotel.amenities.map((amenity) => (
                    <div class="flex items-center">
                      <span class="flex-shrink-0 h-5 w-5 text-primary-green mr-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                      </span>
                      <span class="text-gray-700">{amenity.name}</span>
                    </div>
                  ))}
                </div>
              </div>

              <div>
                <div class="mb-6">
                  <div class="flex justify-between items-center mb-2">
                    <h3 class="text-lg font-medium text-gray-900">Email</h3>
                    <a href={`/dashboard/hotel/${hotel.id}`} class="text-primary-green hover:text-primary-green flex items-center">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"></path>
                      </svg>
                      Edit
                    </a>
                  </div>
                  <p class="text-gray-700">{hotel.email}</p>
                </div>

                <div>
                  <div class="flex justify-between items-center mb-2">
                    <h3 class="text-lg font-medium text-gray-900">Phone Number</h3>
                    <a href={`/dashboard/hotel/${hotel.id}`} class="text-primary-green hover:text-primary-green flex items-center">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"></path>
                      </svg>
                      Edit
                    </a>
                  </div>
                  <p class="text-gray-700">{hotel.phone}</p>
                </div>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-3 gap-4 p-4 bg-gray-50">
            {hotel.images.map((image, index) => (
              <div class={`${index === 0 ? "col-span-2 row-span-2" : ""} aspect-video rounded-lg overflow-hidden bg-gray-200`}>
                <img src={image} alt={`${hotel.name} - Image ${index + 1}`} class="w-full h-full object-cover" />
              </div>
            ))}
          </div>
        </div>
      ))}

      <!-- Add New Hotel Button -->
      <div class="mt-8 flex justify-center">
        <a href="/dashboard/hotel/new" class="px-6 py-3 bg-primary-green text-white rounded-md hover:bg-primary-green flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"></path>
          </svg>
          Add New Hotel
        </a>
      </div>
    </main>
  </div>
</MainLayout>

<script>
  // Add JavaScript for interactive elements here
  document.addEventListener('DOMContentLoaded', () => {
    // No need for edit button event listeners since they're now links
    // Any other dashboard interactions can be added here
  });
</script> 